# Core (not required for WhatsApp webhook smoke test)
DATABASE_URL=
REDIS_URL=redis://localhost:6379

# LLM (Google AI Studio / Gemini API)
GEMINI_API_KEY=
# Optional: gemini-3-flash-preview (default), gemini-3.5-flash, gemini-2.5-flash
GEMINI_MODEL=gemini-3-flash-preview

# WhatsApp — https://green-api.com (console → instance → idInstance + apiTokenInstance)
GREEN_API_INSTANCE=
GREEN_API_TOKEN=

# Optional: if you set webhookUrlToken in Green API, match Bearer token here (future use)
# GREEN_API_WEBHOOK_TOKEN=

SLACK_WEBHOOK_URL=
OPENAI_API_KEY=
CLERK_SECRET_KEY=
